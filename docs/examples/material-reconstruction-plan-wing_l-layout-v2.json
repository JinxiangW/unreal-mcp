      "decision": "Omit World Position Offset and animated vertex branches in the first pass.",
      "impact": "The UE material is visually static and does not reproduce wind or displacement motion."
    },
    {
      "kind": "semantic_conversion",
      "source": "roughness",
      "decision": "Reconstruct roughness as OneMinus(Smoothness) with Smoothness defaulting to 0.0.",
      "impact": "If Unity modifies smoothness downstream in hidden subgraphs, UE gloss response will differ."
